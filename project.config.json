{
  "description": "个税计算器 2026 - 微信小程序",
  "packOptions": {
    "ignore": [
      {
        "type": "folder",
        "value": "node_modules"
      },
      {
        "type": "folder",
        "value": "docs"
      },
      {
        "type": "folder",
        "value": "tests"
      },
      {
        "type": "file",
        "value": ".gitignore"
      },
      {
        "type": "file",
        "value": "README.md"
      }
    ]
  },
  "setting": {
    "bundle": false,
    "userConfirmedBundleSwitch": false,
    "urlCheck": true,
