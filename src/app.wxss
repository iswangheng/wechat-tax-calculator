/* 全局样式 */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333333;
  background: #f5f7fa;
}

/* 全局按钮样式重置 */
button {
  font-size: 28rpx;
  line-height: 1.6;
}

button::after {
  border: none;
}

/* 全局输入框样式 */
input, textarea {
  font-size: 28rpx;
}

/* 通用容器 */
.container {
  min-height: 100vh;
}

/* 通用按钮 */
.btn {
  padding: 24rpx 40rpx;
  border-radius: 16rpx;
  font-weight: bold;
  text-align: center;
  transition: all 0.3s;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.btn-secondary {
  background: #f5f7fa;
  color: #667eea;
  border: 2rpx solid #667eea;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 通用分割线 */
.divider {
  height: 1rpx;
  background: #e9ecef;
  margin: 30rpx 0;
}

/* 通用文本颜色 */
.text-primary {
  color: #667eea;
}

.text-secondary {
  color: #999999;
}

.text-success {
  color: #4caf50;
}

.text-warning {
  color: #ffa726;
}

.text-error {
  color: #f5576c;
}

/* Loading 样式 */
.loading {
  text-align: center;
  padding: 80rpx;
  color: #999999;
}

.loading-icon {
  font-size: 80rpx;
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
