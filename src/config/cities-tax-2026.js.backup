  // 个税全国统一标准
  taxThreshold: 5000,   // 起征点 5000元/月
  taxBrackets: [
    { min: 0, max: 36000, rate: 3, deduction: 0 },
    { min: 36000, max: 144000, rate: 10, deduction: 2520 },
    { min: 144000, max: 300000, rate: 20, deduction: 16920 },
    { min: 300000, max: 420000, rate: 25, deduction: 31920 },
