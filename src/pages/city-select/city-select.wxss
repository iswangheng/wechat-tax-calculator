/* 城市选择页面样式 */

/* ========== 容器 ========== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffecd2 0%, #fcb69f 100%);
  padding-bottom: 40rpx;
}

/* ========== 头部 ========== */
.header {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  padding: 60rpx 30rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(240, 147, 251, 0.3);
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 2rpx;
}

/* ========== 搜索框 ========== */
.search-container {
  margin: 20rpx 30rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-icon {
  font-size: 32rpx;
  color: #999999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.clear-btn {
  font-size: 32rpx;
  color: #999999;
  padding: 0 8rpx;
}

/* ========== 热门城市 ========== */
.hot-cities-section {
  margin: 30rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.title-icon {
  margin-right: 8rpx;
}

.cities-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.city-item {
  padding: 24rpx 0;
  background: #f8f9fa;
  border-radius: 12rpx;
  text-align: center;
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.city-item-active {
  background: linear-gradient(135deg, #f093fb10 0%, #f5576c10 100%);
  border-color: #f5576c;
}

.city-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.city-level {
  font-size: 22rpx;
  color: #999999;
}

.city-item-active .city-name {
  color: #f5576c;
  font-weight: bold;
}

.city-item-active .city-level {
  color: #f5576c;
}

/* ========== 城市列表 ========== */
.cities-list-section {
  margin: 30rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.level-group {
  margin-bottom: 30rpx;
}

.level-group:last-child {
  margin-bottom: 0;
}

.level-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #666666;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.level-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #ffffff;
  font-weight: bold;
}

.badge-tier1 {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.badge-tier2 {
  background: linear-gradient(135deg, #ffa726 0%, #fb8c00 100%);
}

.badge-tier3 {
  background: linear-gradient(135deg, #66bb6a 0%, #43a047 100%);
}

.cities-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.city-list-item {
  padding: 20rpx 0;
  background: #f8f9fa;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  color: #333333;
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.city-list-item-active {
  background: linear-gradient(135deg, #f093fb10 0%, #f5576c10 100%);
  border-color: #f5576c;
  color: #f5576c;
  font-weight: bold;
}

/* ========== 搜索结果 ========== */
.search-results {
  margin: 30rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.result-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.3s;
}

.result-item:last-child {
  border-bottom: none;
}

.result-item:active {
  background: #f8f9fa;
}

.result-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.result-info {
  font-size: 24rpx;
  color: #999999;
}

.no-result {
  padding: 60rpx 0;
  text-align: center;
}

.no-result-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.no-result-text {
  font-size: 28rpx;
  color: #999999;
}

/* ========== 底部提示 ========== */
.footer-tip {
  margin: 30rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tip-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.tip-content {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.tip-item {
  padding: 8rpx 0;
}

/* ========== 确认按钮 ========== */
.confirm-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.btn-confirm {
  width: 100%;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 16rpx;
  padding: 28rpx 0;
  box-shadow: 0 8rpx 20rpx rgba(240, 147, 251, 0.4);
  border: none;
}

.btn-confirm-disabled {
  background: #e9ecef;
  color: #999999;
  box-shadow: none;
}

/* ========== 标签徽章 ========== */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  margin-left: 8rpx;
}

.tag-hot {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a52 100%);
  color: #ffffff;
}

.tag-new {
  background: linear-gradient(135deg, #4caf50 0%, #43a047 100%);
  color: #ffffff;
}

/* ========== 加载状态 ========== */
.loading-container {
  padding: 60rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
  margin-top: 20rpx;
}

/* ========== 空状态 ========== */
.empty-container {
  padding: 100rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* ========== 索引导航 ========== */
.index-nav {
  position: fixed;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  z-index: 99;
}

.index-item {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  font-size: 20rpx;
  color: #666666;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.index-item-active {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #ffffff;
  font-weight: bold;
  transform: scale(1.2);
}
