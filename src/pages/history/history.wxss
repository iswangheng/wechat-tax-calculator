/* History page styles */

/* ========== Container ========== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffecd2 0%, #fcb69f 100%);
  padding-bottom: 40rpx;
}

/* ========== Header ========== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
}

.header-action {
  padding: 12rpx 28rpx;
  background: rgba(245, 87, 108, 0.1);
  border-radius: 20rpx;
}

.clear-text {
  font-size: 26rpx;
  color: #059048;
  font-weight: 500;
}

/* ========== Empty state ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 60rpx;
}

.btn-go-calculate {
  background: linear-gradient(135deg, #07C160 0%, #059048 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 16rpx;
  padding: 24rpx 80rpx;
  box-shadow: 0 8rpx 20rpx rgba(240, 147, 251, 0.4);
}

/* ========== History list ========== */
.history-list {
  padding: 0 20rpx;
}

/* ========== History card ========== */
.history-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-content {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  position: relative;
  z-index: 1;
  transition: transform 0.3s ease;
}

.history-card.swiped .card-content {
  transform: translateX(-160rpx);
}

/* ========== Card header ========== */
.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.type-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: bold;
  margin-right: 12rpx;
}

.type-badge.salary {
  background: #e3f2fd;
  color: #1976d2;
}

.type-badge.bonus {
  background: #fff3e0;
  color: #e65100;
}

.card-city {
  font-size: 24rpx;
  color: #666666;
  margin-right: auto;
}

.card-time {
  font-size: 22rpx;
  color: #999999;
}

/* ========== Card title ========== */
.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

/* ========== Card data ========== */
.card-data {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.data-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.data-label {
  font-size: 22rpx;
  color: #999999;
}

.data-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.data-value.green {
  color: #4caf50;
}

.data-value.red {
  color: #059048;
}

/* ========== Card hint ========== */
.card-hint {
  text-align: center;
}

.hint-text {
  font-size: 20rpx;
  color: #cccccc;
}

/* ========== Swipe delete button ========== */
.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #059048;
  border-radius: 0 20rpx 20rpx 0;
  z-index: 0;
}

.delete-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

/* ========== Record count ========== */
.record-count {
  text-align: center;
  padding: 30rpx;
}

.count-text {
  font-size: 24rpx;
  color: #999999;
}
