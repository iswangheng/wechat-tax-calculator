<!-- Onboarding guide page -->
<view class="onboarding-container">
  <!-- Skip button -->
  <view class="skip-btn" bindtap="onSkip" wx:if="{{currentIndex < 2}}">
    <text>跳过</text>
  </view>

  <!-- Swiper slides -->
  <swiper
    class="onboarding-swiper"
    current="{{currentIndex}}"
    bindchange="onSwiperChange"
    duration="300"
    circular="{{false}}"
  >
    <!-- Step 1: Precise tax calculation -->
    <swiper-item>
      <view class="slide-content">
        <view class="icon-wrapper">
          <view class="icon-circle">
            <text class="icon-text">&#xe610;</text>
          </view>
        </view>
        <view class="slide-title">精准算税</view>
        <view class="slide-desc">支持累计预扣法</view>
        <view class="slide-desc">自动计算五险一金</view>
      </view>
    </swiper-item>

    <!-- Step 2: Bonus optimization -->
    <swiper-item>
      <view class="slide-content">
        <view class="icon-wrapper">
          <view class="icon-circle">
            <text class="icon-text">&#xe611;</text>
          </view>
        </view>
        <view class="slide-title">年终奖优化</view>
        <view class="slide-desc">智能检测临界点</view>
        <view class="slide-desc">一键优化节税</view>
      </view>
    </swiper-item>

    <!-- Step 3: Get started -->
    <swiper-item>
      <view class="slide-content">
        <view class="icon-wrapper">
          <view class="icon-circle icon-circle-start">
            <text class="icon-text">&#xe612;</text>
          </view>
        </view>
        <view class="slide-title">开始使用</view>
        <view class="slide-desc">轻松掌握个税信息</view>
        <view class="slide-desc">做出最优税务规划</view>
        <view class="start-btn" bindtap="onStart">
          <text>立即开始</text>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <!-- Dot indicators -->
  <view class="dot-indicators">
    <view
      class="dot {{currentIndex === index ? 'dot-active' : ''}}"
      wx:for="{{steps}}"
      wx:key="index"
    ></view>
  </view>
</view>
