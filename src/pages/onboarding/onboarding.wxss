/* Onboarding page styles - pink gradient theme */
.onboarding-container {
  width: 100%;
  height: 100vh;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* Skip button */
.skip-btn {
  position: absolute;
  top: 100rpx;
  right: 40rpx;
  z-index: 10;
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.2);
}

.skip-btn text {
  color: #ffffff;
  font-size: 28rpx;
}

/* Swiper */
.onboarding-swiper {
  width: 100%;
  height: 70vh;
}

/* Slide content */
.slide-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 60rpx;
}

/* Icon */
.icon-wrapper {
  margin-bottom: 60rpx;
}

.icon-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.icon-circle-start {
  background: rgba(255, 255, 255, 0.25);
  border-color: rgba(255, 255, 255, 0.5);
}

.icon-text {
  font-size: 80rpx;
  color: #ffffff;
}

/* Title */
.slide-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 30rpx;
  letter-spacing: 4rpx;
}

/* Description */
.slide-desc {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 50rpx;
  text-align: center;
}

/* Start button */
.start-btn {
  margin-top: 80rpx;
  width: 400rpx;
  height: 88rpx;
  background: #ffffff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}

.start-btn text {
  font-size: 32rpx;
  font-weight: bold;
  color: #f5576c;
  letter-spacing: 4rpx;
}

/* Dot indicators */
.dot-indicators {
  position: absolute;
  bottom: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.4);
  margin: 0 10rpx;
  transition: all 0.3s ease;
}

.dot-active {
  width: 40rpx;
  background: #ffffff;
}
