/* Privacy Policy Page Styles */
.privacy-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.privacy-header {
  background-color: #ffffff;
  padding: 40rpx 32rpx 30rpx;
  border-bottom: 1px solid #e8e8e8;
}

.privacy-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #07C160;
  margin-bottom: 16rpx;
}

.update-date {
  display: block;
  font-size: 24rpx;
  color: #8c8c8c;
}

.privacy-content {
  flex: 1;
  padding: 0 32rpx;
}

.section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-top: 24rpx;
}

.last-section {
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #262626;
  margin-bottom: 20rpx;
}

.section-text {
  display: block;
  font-size: 28rpx;
  line-height: 44rpx;
  color: #595959;
  margin-bottom: 16rpx;
}

.section-text:last-child {
  margin-bottom: 0;
}

.section-text.indent {
  padding-left: 24rpx;
  margin-bottom: 12rpx;
}

.highlight-text {
  display: block;
  font-size: 28rpx;
  line-height: 44rpx;
  color: #07C160;
  font-weight: 500;
  margin-bottom: 12rpx;
  padding-left: 12rpx;
}

.privacy-footer {
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1px solid #e8e8e8;
}

.agree-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #07C160 0%, #059048 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.agree-btn::after {
  border: none;
}
