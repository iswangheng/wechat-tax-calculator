<!-- Reverse calculation page: net salary -> gross salary -->
<view class="container">

  <!-- City selection -->
  <view class="section city-section">
    <view class="section-title">📍 选择城市</view>
    <view class="city-selector" bindtap="onCitySelect">
      <text class="city-name">{{cityName}}</text>
      <text class="city-level">{{cityLevel}}</text>
      <text class="arrow">></text>
    </view>
    <view class="city-info" wx:if="{{cityInfo}}">
      <text class="info-item">社保基数: {{cityInfo.socialBase.min}}-{{cityInfo.socialBase.max}}元</text>
      <text class="info-item">总费率: {{cityInfo.totalRate}}%</text>
    </view>
  </view>

  <!-- Net salary input -->
  <view class="section">
    <view class="section-title">💰 期望税后工资（月薪）</view>
    <view class="input-group">
      <input
        type="digit"
        placeholder="请输入期望税后到手工资"
        value="{{netSalary}}"
        bindinput="onNetSalaryInput"
        class="input-number"/>
      <text class="unit">元</text>
    </view>
    <view class="info-tip">
      💡 输入你想到手的金额，系统反推需要多少税前工资
    </view>
  </view>

  <!-- Housing fund ratio -->
  <view class="section">
    <view class="section-title">🏦 公积金比例</view>
    <view class="input-group">
      <text class="label">公积金比例</text>
      <slider
        value="{{fundRatio}}"
        min="{{fundMin}}"
        max="{{fundMax}}"
        step="1"
        show-value
        bindchange="onFundRatioChange"
        class="slider"/>
      <text class="unit">%</text>
    </view>
  </view>

  <!-- Special deductions -->
  <view class="section">
    <view class="section-title">
      📋 专项附加扣除
      <text class="edit-btn" bindtap="onEditDeductions">编辑</text>
    </view>
    <view class="deduction-summary">
      <text class="summary-text">本月可扣除: ¥{{specialDeductions}}</text>
      <view class="deduction-items" wx:if="{{deductionItems && deductionItems.length > 0}}">
        <text class="item" wx:for="{{deductionItems}}" wx:key="name">
          {{item.name}} ¥{{item.amount}}
        </text>
      </view>
    </view>
  </view>

  <!-- Month selector -->
  <view class="section">
    <view class="section-title">📅 计算月份</view>
    <view class="input-group">
      <text class="label">当前月份</text>
      <picker mode="selector" range="{{monthOptions}}" value="{{monthIndex}}" bindchange="onMonthChange">
        <view class="picker-value">{{monthOptions[monthIndex]}} ▼</view>
      </picker>
    </view>
    <view class="info-tip">
      💡 累计预扣法下，不同月份税额不同，年末月份税前工资会更高
    </view>
  </view>

  <!-- Action buttons -->
  <view class="btn-group">
    <button class="btn-calculate" bindtap="onCalculate">开始反推</button>
    <button class="btn-reset" bindtap="onReset">重置</button>
  </view>

  <!-- Result display -->
  <view class="result-section" wx:if="{{result}}">
    <view class="result-title">📈 反推结果</view>

    <!-- Core result -->
    <view class="result-highlight">
      <view class="highlight-item">
        <text class="highlight-label">需要税前工资</text>
        <text class="highlight-value red">¥{{result.grossSalary}}</text>
      </view>
      <view class="highlight-desc">
        税后到手 ¥{{result.netSalary}}
      </view>
    </view>

    <!-- Deduction breakdown -->
    <view class="deduction-breakdown">
      <view class="breakdown-title">扣除明细</view>
      <view class="breakdown-item">
        <text class="breakdown-label">税前工资</text>
        <text class="breakdown-value">¥{{result.grossSalary}}</text>
      </view>
      <view class="breakdown-item">
        <text class="breakdown-label">五险一金</text>
        <text class="breakdown-value red">- ¥{{result.socialSecurity}}</text>
      </view>
      <view class="breakdown-item">
        <text class="breakdown-label">个人所得税</text>
        <text class="breakdown-value red">- ¥{{result.tax}}</text>
      </view>
      <view class="breakdown-item total">
        <text class="breakdown-label">扣除合计</text>
        <text class="breakdown-value red">- ¥{{result.totalDeduction}}</text>
      </view>
      <view class="breakdown-item result-net">
        <text class="breakdown-label">税后到手</text>
        <text class="breakdown-value green">¥{{result.netSalary}}</text>
      </view>
    </view>

    <!-- Social security breakdown -->
    <view class="social-detail" wx:if="{{socialSecurity}}">
      <view class="detail-title">五险一金明细</view>
      <view class="detail-row">
        <text class="detail-label">养老保险 (8%)</text>
        <text class="detail-value">¥{{socialSecurity.pension}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">医疗保险 (2%)</text>
        <text class="detail-value">¥{{socialSecurity.medical}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">失业保险</text>
        <text class="detail-value">¥{{socialSecurity.unemployment}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">公积金 ({{fundRatio}}%)</text>
        <text class="detail-value">¥{{socialSecurity.fund}}</text>
      </view>
      <view class="detail-row total">
        <text class="detail-label">五险一金合计</text>
        <text class="detail-value">¥{{socialSecurity.total}}</text>
      </view>
    </view>
  </view>

</view>
