/* Reverse calculation page styles */

/* ========== Container ========== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffecd2 0%, #fcb69f 100%);
  padding-bottom: 40rpx;
}

/* ========== Section ========== */
.section {
  margin: 30rpx 30rpx 0;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.edit-btn {
  margin-left: auto;
  font-size: 24rpx;
  color: #07C160;
  padding: 8rpx 20rpx;
  background: #e8f5e9;
  border-radius: 20rpx;
}

/* ========== City selection ========== */
.city-section {
  background: linear-gradient(135deg, #07C160 0%, #059048 100%);
  color: #ffffff;
}

.city-selector {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.city-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.city-level {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 20rpx;
  margin-right: auto;
}

.arrow {
  font-size: 32rpx;
  color: #ffffff;
}

.city-info {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
}

.info-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* ========== Input ========== */
.input-group {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 24rpx 30rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid #e9ecef;
}

.label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 20rpx;
  white-space: nowrap;
}

.input-number {
  flex: 1;
  font-size: 32rpx;
  color: #333333;
  text-align: right;
}

.unit {
  font-size: 28rpx;
  color: #999999;
  margin-left: 16rpx;
}

.slider {
  flex: 1;
  margin: 0 20rpx;
}

.info-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999999;
  padding: 16rpx 20rpx;
  background: #e3f2fd;
  border-radius: 12rpx;
  color: #1976d2;
}

/* ========== Deductions ========== */
.deduction-summary {
  padding: 24rpx;
  background: #fff8e1;
  border-radius: 16rpx;
  border-left: 4rpx solid #ffa726;
}

.summary-text {
  font-size: 28rpx;
  color: #f57c00;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.deduction-items {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.deduction-items .item {
  font-size: 24rpx;
  color: #ef6c00;
  background: #ffffff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid #ffb74d;
}

/* ========== Buttons ========== */
.btn-group {
  display: flex;
  gap: 20rpx;
  margin: 40rpx 30rpx 0;
}

.btn-calculate {
  flex: 2;
  background: linear-gradient(135deg, #07C160 0%, #059048 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 16rpx;
  padding: 28rpx 0;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.4);
}

.btn-reset {
  flex: 1;
  background: #f5f7fa;
  color: #666666;
  font-size: 28rpx;
  border-radius: 16rpx;
  padding: 28rpx 0;
}

/* ========== Result ========== */
.result-section {
  margin: 30rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
  text-align: center;
}

.result-highlight {
  background: linear-gradient(135deg, #07C16015 0%, #05904815 100%);
  padding: 32rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.highlight-item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.highlight-label {
  font-size: 28rpx;
  color: #666666;
}

.highlight-value {
  font-size: 48rpx;
  font-weight: bold;
  word-break: break-all;
}

.highlight-value.green {
  color: #4caf50;
}

.highlight-value.red {
  color: #e65100;
}

.highlight-desc {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999999;
  word-break: break-all;
}

/* ========== Breakdown ========== */
.deduction-breakdown {
  margin-bottom: 30rpx;
}

.breakdown-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.breakdown-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.breakdown-item:last-child {
  border-bottom: none;
}

.breakdown-item.total {
  padding-top: 24rpx;
  border-top: 2rpx solid #e9ecef;
  margin-top: 8rpx;
}

.breakdown-item.result-net {
  background: linear-gradient(135deg, #e8f5e915 0%, #c8e6c915 100%);
  padding: 20rpx;
  margin: 16rpx -20rpx 0;
  border-radius: 12rpx;
  border: none;
}

.breakdown-label {
  font-size: 26rpx;
  color: #666666;
}

.breakdown-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.breakdown-value.red {
  color: #e65100;
}

.breakdown-value.green {
  color: #4caf50;
}

.result-net .breakdown-label,
.result-net .breakdown-value {
  font-weight: bold;
}

/* ========== Social detail ========== */
.social-detail {
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.detail-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx dashed #e9ecef;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-row.total {
  background: linear-gradient(135deg, #07C16015 0%, #05904815 100%);
  padding: 20rpx;
  margin: 16rpx -24rpx 0;
  border-radius: 12rpx;
  border: none;
}

.detail-label {
  font-size: 26rpx;
  color: #666666;
}

.detail-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.detail-row.total .detail-label,
.detail-row.total .detail-value {
  font-weight: bold;
  color: #059048;
}
